[web]
web-server ansible_host=YOUR_WEB_PUBLIC_IP ansible_user=ubuntu ansible_ssh_private_key_file=~/.ssh/YOUR_KEY.pem

[db]
db-server ansible_host=10.0.2.10 ansible_user=ubuntu ansible_ssh_private_key_file=~/.ssh/YOUR_KEY.pem ansible_ssh_common_args='-o ProxyJump=ubuntu@YOUR_WEB_PUBLIC_IP'

[all:vars]
ansible_python_interpreter=/usr/bin/python3
